<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/assets/css/styles.css">
    <link rel="stylesheet" href="/assets/css/menu.css">
    <link rel="stylesheet" href="/assets/css/product.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Chocolate+Classical+Sans&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar">
        <div class="nav-left">
            <img class="logo" src="/assets/images/logo.png" alt="Logo">
        </div>

        <div class="nav-right">
            <ul class="nav-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/menu">Offers</a></li>
                <li><a href="/#menu-container">Know More</a></li>
                <li><a href="/orders">Your Order</a></li>
                <li><a href="/cart">Cart (<span id="cartSize">0</span>)</a></li>
            </ul>
            <button id="login-button"><a href="/signup">Login</a></button>
        </div>
    </nav>

    <div class="product-details-container">
        <div class="product-details-card">
            <% if (product) { %>
                <div id="product-image" class="product-image" style="background-image: url('<%= product.image %>');"></div>
                <div class="product-details">
                    <h1 id="product-name"><%= product.title %></h1>
                    <span class="star-rating">
                        <i class="fa-regular fa-star star" data-value="1"></i>
                        <i class="fa-regular fa-star star" data-value="2"></i>
                        <i class="fa-regular fa-star star" data-value="3"></i>
                        <i class="fa-regular fa-star star" data-value="4"></i>
                        <i class="fa-regular fa-star star" data-value="5"></i>
                    </span>
                    <p id="product-description"><%= product.description %></p>
                    <p id="product-price" class="product-price">Price: Rs. <%= product.price.toFixed(2) %></p>
                    <div class="product-buttons">
                        <button class="add-to-cart-button">Add to Cart</button>
                        <button class="buy-now">Order It</button>
                    </div>
                </div>
            <% } else { %>
                <div class="product-not-found">
                    <h1>Item not found</h1>
                    <p>This menu item is unavailable or the link is incorrect.</p>
                    <a href="/menu">Back to menu</a>
                </div>
            <% } %>
        </div>
    </div>

    <div class="footer">
        <div class="footer-top">
            <div class="footer-section-1">
                <img class="logo" src="/assets/images/logo.png" alt="Logo">
            </div>
            <div class="footer-section-2">
                <h1>Quick links</h1>
                <span>Our Menu</span>
                <span>Our Offers</span>
                <span>Know what we have Achieved</span>
            </div>
            <div class="footer-section-3">
                <h1>Wanna Get Updated with Our Exciting Offers?</h1>
                <span>Follow us on</span>
                <span>Instagram | Facebook | Twitter</span>
                <form action="/menu">
                    <input type="email" placeholder="Enter for daily exciting offers" class="email-input">
                    <button>Subscribe</button>
                </form>
            </div>
        </div>
        <div class="footer-bottom">
            Terms & Conditions | Privacy Policy | All Rights Reserved
        </div>
    </div>

    <script src="/assets/js/models/menuList.js"></script>
    <script src="/assets/js/controllers/star.js"></script>
    <script src="/assets/js/controllers/product.js"></script>
    <script src="/assets/js/controllers/CartSize.js"></script>
</body>
</html>
