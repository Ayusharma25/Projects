<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/assets/css/styles.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-left">
            <img class="logo" src="/assets/images/logo.png" alt="Logo">
        </div>

        <div class="nav-right">
            <ul class="nav-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/menu">Menu</a></li>
                <li><a href="/menu">Offers</a></li>
                <li><a href="/#menu-container">Know More</a></li>
                <li><a href="/orders">Your Order</a></li>
                <li><a href="/cart">Cart (<span id="cartSize">0</span>)</a></li>
            </ul>
            <button id="login-button"><a href="/signup">Login</a></button>
        </div>
    </nav>

    <div class="banner"></div>

    <div id="all-offers-container">
        <a id="all-offers" href="/menu">Checkout All Offers</a>
    </div>

    <div id="menu-container">
        <span id="menu-title">Our Menu</span>
        <hr id="menu-title-underline">
        <div class="top-3-component">
            <div class="top-3-title">
                <span>Best Seller</span>
                <a href="/menu">View All</a>
            </div>
            <div class="top-3-card">
                <% featuredItems.forEach((item) => { %>
                    <div class="food-card">
                        <img src="<%= item.image %>" alt="<%= item.title %>" class="food-image">
                        <span class="food-card-name"><%= item.title %></span>
                        <span class="food-card-description"><%= item.description %></span>
                        <span class="food-card-price">Price: Rs. <%= item.price.toFixed(2) %></span>
                        <a class="add-to-cart-button" href="/product?id=<%= item.id %>">View Item</a>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>

    <div class="footer">
        <div class="footer-top">
            <div class="footer-section-1">
                <img class="logo" src="/assets/images/logo.png" alt="Logo">
            </div>
            <div class="footer-section-2">
                <h1>Quick links</h1>
                <span>Our Menu</span>
                <span>Our Offers</span>
                <span>Know what we have Achieved</span>
            </div>
            <div class="footer-section-3">
                <h1>Wanna Get Updated with Our Exciting Offers?</h1>
                <span>Follow us on</span>
                <span>Instagram | Facebook | Twitter</span>
                <form action="/menu">
                    <input type="email" placeholder="Enter for daily exciting offers" class="email-input">
                    <button>Subscribe</button>
                </form>
            </div>
        </div>
        <div class="footer-bottom">
            Terms & Conditions | Privacy Policy | All Rights Reserved
        </div>
    </div>

    <script src="/assets/js/controllers/CartSize.js"></script>
</body>
</html>
